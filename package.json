    "@types/node": "24.10.2",
    "@types/nodemailer": "7.0.4",
    "@types/pg": "8.16.0",
    "@types/supertest": "6.0.3",
    "@types/validator": "13.15.10",
    "@vitest/coverage-v8": "4.0.14",
    "@vitest/ui": "4.0.14",
    "prisma": "7.6.0",
    "supertest": "7.1.4",
    "tsx": "4.21.0",
