{
  "name": "test_ai",
  "version": "1.0.0",
  "description": "",
  "main": "test.js",
  "scripts": {
    "dev:server": "tsx watch ./src/apps/api/server-start.ts",
    "dev:queue": "tsx watch ./src/apps/message-queue/start-queue.ts",
    "dev:jobs": "tsx watch ./src/apps/jobs/start-jobs.ts",
    "build": "tsc",
    "start:api": "node dist/apps/api/server-start.js",
    "start:queue": "node dist/apps/message-queue/start-queue.js",
    "start:jobs": "node dist/apps/jobs/start-jobs.js",
    "db:create": "npx sequelize-cli db:create",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo",
    "db:seed": "npx sequelize-cli db:seed:all",
    "db:reset": "npx sequelize-cli db:drop && npx sequelize-cli db:create && npx sequelize-cli db:migrate && npx sequelize-cli db:seed:all",
    "ts:check": "npx tsc --noEmit",
    "test": "vitest",
    "lint": "npx @biomejs/biome lint --max-diagnostics 100",
    "format": "npx @biomejs/biome format --write ./src",
    "organize:all": "npx @biomejs/biome check --write ./src",
    "w:kill:port": "kill-windows-port.bat"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@fastify/jwt": "10.0.0",
    "amqplib": "0.10.9",
    "bcryptjs": "3.0.3",
    "fastify": "5.6.2",
    "fastify-type-provider-zod": "6.1.0",
    "ioredis": "5.8.2",
    "node-cron": "4.2.1",
    "nodemailer": "7.0.12",
    "pg": "8.16.3",
    "pg-hstore": "2.3.4",
    "pino": "10.1.0",
    "pino-pretty": "13.1.3",
    "reflect-metadata": "0.2.2",
    "sequelize": "6.37.7",
    "sequelize-typescript": "2.1.6",
    "uuidv7": "1.1.0",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@tsconfig/node24": "24.0.3",
    "@types/amqplib": "0.10.8",
    "@types/node": "24.10.2",
    "@types/nodemailer": "7.0.4",
    "@types/supertest": "6.0.3",
    "@types/validator": "13.15.10",
    "sequelize-cli": "6.6.3",
    "supertest": "7.1.4",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.0.14"
  }
}