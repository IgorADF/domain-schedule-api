{
  "name": "test_ai",
  "version": "1.0.0",
  "description": "",
  "main": "test.js",
  "scripts": {
    "dev:server": "npx tsx watch ./src/apps/api/server-start.ts",
    "dev:queue": "npx tsx watch ./src/apps/queue/start-queue.ts",
    "dev:jobs": "npx tsx watch ./src/apps/jobs/start-jobs.ts",
    "build": "npx tsx ./scripts/build.ts",
    "start:api": "node dist/apps/api/server-start.js",
    "start:queue": "node dist/apps/queue/start-queue.js",
    "start:jobs": "node dist/apps/jobs/start-jobs.js",
    "server:tests": "vitest run ./src/apps/api/tests",
    "server:coverage:tests": "vitest run --coverage ./src/apps/api/tests",
    "tests:ui": "vitest --ui",
    "ts:check": "npx tsc --noEmit",
    "lint": "npx @biomejs/biome lint --max-diagnostics 100",
    "format": "npx @biomejs/biome format --write ./src",
    "organize:all": "npx @biomejs/biome check --write ./src",
    "organize:check": "npm run organize:all && npm run ts:check",
    "kill:port": "./scripts/kill-windows-port.bat",
    "db:generate": "npx prisma generate --sql",
    "db:migrate:dev": "npm run db:generate && npx prisma migrate dev",
    "db:migrate:deploy": "npx prisma migrate deploy",
    "generate:swagger": "npx tsx ./scripts/generate-swagger.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@fastify/swagger": "9.6.1",
    "@fastify/swagger-ui": "5.2.4",
    "@prisma/adapter-pg": "7.2.0",
    "@prisma/client": "7.2.0",
    "amqplib": "0.10.9",
    "bcryptjs": "3.0.3",
    "cookie": "1.1.1",
    "dotenv": "17.2.3",
    "fastify": "5.8.4",
    "fastify-type-provider-zod": "6.1.0",
    "ioredis": "5.8.2",
    "jsonwebtoken": "9.0.3",
    "luxon": "3.7.2",
    "node-cron": "4.2.1",
    "nodemailer": "8.0.4",
    "pg": "8.16.3",
    "pino": "10.1.0",
    "pino-pretty": "13.1.3",
    "uuidv7": "1.1.0",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@tsconfig/node24": "24.0.3",
    "@types/amqplib": "0.10.8",
    "@types/jsonwebtoken": "9.0.10",
