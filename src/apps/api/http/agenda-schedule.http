###

# @name ListSellerSchedules
GET {{BASE_URL}}/agenda-schedules?initialDate=2026-01-01&finalDate=2026-01-31

###

# @name CreateAgendaScheduleNormalSlot
POST {{BASE_URL}}/agenda-schedules
Content-Type: application/json

{
	"agendaConfigId": "{{AGENDA_CONFIG_ID}}",
	"contactName": "John Doe",
	"contactPhoneNumber": "+5511987654321",
	"day": {
		"year": 2026,
		"month": 1,
		"day": 5
	},
	"startTime": {
		"hour": 9,
		"minute": 0
	},
	"endTime": {
		"hour": 10,
		"minute": 0
	}
}

