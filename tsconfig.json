{
  "extends": "@tsconfig/node24/tsconfig.json",

  "compilerOptions": {
    "strict": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "ES2023",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "outDir": "./dist",

    "allowJs": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@domain/*": ["./src/domain/*"],
      "@infra/*": ["./src/infra/*"],
      "@api/*": ["./src/apps/api/*"],
      "@queue/*": ["./src/apps/queue/*"]
    }
  },
  "exclude": ["src/**/*.js", "src/**/*.cjs"]
}
