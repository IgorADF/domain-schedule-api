###############################################
################### General ###################
###############################################
TZ=UTC
NODE_ENV=test
API_PORT=3000
API_AUTH_JWT_SECRET=your_test_jwt_secret_key_here
API_REFRESH_JWT_SECRET=your_test_refresh_jwt_secret_key_here
API_JWT_RESET_SECRET=your_test_reset_password_jwt_secret_key_here

###############################################
##################### DBs #####################
###############################################
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/new_schedule

REDIS_ENABLE=false
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

###############################################
#################### Queue ####################
###############################################
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin #Only for rabbitmq ui access
RABBITMQ_PASS=admin #Only for rabbitmq ui access
RABBITMQ_MANAGEMENT_PORT=15672 #Only for rabbitmq ui access

###############################################
#################### Email ####################
###############################################
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password
EMAIL_FROM=noreply@yourapp.com